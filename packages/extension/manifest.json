{
  "manifest_version": 3,
  "name": "ClawOS Plugin",
  "version": "0.1.0",
  "description": "ClawOS Plugin — 招聘平台 CLI 自动化",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["tabs", "activeTab", "scripting", "debugger", "storage", "alarms", "history"],
  "host_permissions": ["<all_urls>"],
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/trace.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["buildDomTree.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
